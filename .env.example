# --- HTTP server ----------------------------------------------------
PORT=3000
HOST=0.0.0.0

# Mount mọi data endpoint dưới prefix này. UI/admin/docs vẫn ở root.
# Empty = không prefix. Ví dụ: /api/v1
API_PREFIX=

# --- MongoDB --------------------------------------------------------
# Local (no auth):   mongodb://localhost:27017
# Local (with auth): mongodb://<user>:<pass>@localhost:27017/?authSource=admin
# Atlas:             mongodb+srv://<user>:<pass>@cluster.xxx.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DB=zalo_auto

# --- Crypto (REQUIRED) ----------------------------------------------
# 32-byte hex (64 ký tự). Sinh ngẫu nhiên:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mất key này = toàn bộ credentials không recover được. BACKUP NGOÀI SERVER.
ENCRYPTION_KEY=

# --- Admin (UI dashboard) auth -------------------------------------
# Set cả 3 dòng dưới để bật login. Empty = UI open mode (dev only).
# API key cho client → tạo qua /api-keys.html (DB-backed, có TTL + revoke).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_SECRET=
# Cookie lifetime (giây). Default 7 ngày.
SESSION_TTL_SEC=604800

# --- API key bootstrap (TUỲ CHỌN) ----------------------------------
# Master key đặt sẵn ở env. Hữu ích nếu cần programmatic access trước
# khi admin login + tạo DB keys. Leave empty trong production khi đã
# có DB keys — recommended workflow.
API_KEY=

# --- CORS -----------------------------------------------------------
# Empty = same-origin only. * = allow all. Hoặc danh sách phẩy:
#   https://app.example.com,https://staging.example.com
CORS_ORIGINS=

# --- Rate limit -----------------------------------------------------
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60

# --- Background keep-alive -----------------------------------------
# Ping Zalo session mỗi N giây. Zalo cut session sau ~5 phút idle.
KEEPALIVE_INTERVAL_SEC=240

# --- Idle session eviction -----------------------------------------
# Drop pooled session sau N giây không touch. Lazy re-create khi gọi
# tiếp. Session có WS subscriber / webhook đang nghe sẽ KHÔNG bị drop.
IDLE_EVICT_AFTER_SEC=21600

# --- Logging --------------------------------------------------------
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
