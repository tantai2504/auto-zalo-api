# --- HTTP server ----------------------------------------------------
PORT=3000
HOST=0.0.0.0

# --- MongoDB --------------------------------------------------------
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://user:pass@cluster.xxx.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DB=zalo_auto

# --- Crypto (REQUIRED) ----------------------------------------------
# 32-byte hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Losing this key means every stored credential is unrecoverable.
ENCRYPTION_KEY=

# --- Logging --------------------------------------------------------
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Auth -----------------------------------------------------------
# Programmatic API access. Sent as `Authorization: Bearer <key>` or `X-API-Key: <key>`.
# Leave empty if you only want admin (cookie) auth from the UI.
API_KEY=

# --- Admin (UI dashboard) auth -------------------------------------
# Set ALL THREE to require login at /login.html for UI pages.
# Leave empty to keep UI open (dev mode).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# 32-byte hex secret for signing the session cookie.
# Generate with the same command as ENCRYPTION_KEY.
SESSION_SECRET=
# Cookie lifetime in seconds (default 7 days)
SESSION_TTL_SEC=604800

# --- CORS -----------------------------------------------------------
# Comma-separated origins (e.g. https://yourapp.com,https://staging.yourapp.com).
# Use * to allow any origin. Empty disables CORS headers (same-origin only).
CORS_ORIGINS=

# --- Rate limit -----------------------------------------------------
# Per-IP max requests within the window. 0 disables.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60

# --- Background keep-alive -----------------------------------------
# Period (seconds) between keepAlive() calls per active session.
# Zalo cuts idle sessions ~5 minutes; default 240s = 4 minutes is safe.
# Set 0 to disable (sessions will only stay alive while serving requests).
KEEPALIVE_INTERVAL_SEC=240
